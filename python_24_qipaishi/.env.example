QIPAISHI_APP_NAME=Qipaishi API
QIPAISHI_APP_VERSION=0.1.0
QIPAISHI_ENV=dev
QIPAISHI_API_V1_PREFIX=/api/v1
QIPAISHI_DATABASE_URL=postgresql+asyncpg://qipaishi:qipaishi@localhost:5432/qipaishi
QIPAISHI_REDIS_URL=redis://localhost:6379/0
QIPAISHI_TOKEN_SECRET=change-me-in-production
QIPAISHI_ACCESS_TOKEN_TTL_SECONDS=86400
QIPAISHI_HEALTH_CHECK_DATABASE=true
QIPAISHI_HEALTH_CHECK_REDIS=true
QIPAISHI_LOG_LEVEL=INFO
